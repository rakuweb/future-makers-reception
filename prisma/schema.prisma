// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Participant {
  id          String   @id @default(uuid())
  name        String
  affiliation String
  grade       String
  studentId   String   @unique
  checkedInAt DateTime @default(now())
}
